{
  "name": "send_whatsapp_message",
  "site": "whatsapp",
  "goal_template": "Send a WhatsApp message to {recipient_name} with the text: {message_text}",
  "params": [
    {"name": "recipient_name", "type": "str", "required": true},
    {"name": "message_text",   "type": "str", "required": true},
    {"name": "attachment_path","type": "str", "required": false}
  ],
  "preconditions": {
    "url_pattern": null,
    "landmarks": ["Chats tab", "search icon", "message input bar"]
  },
  "steps": [
    {"intent": "Open the WhatsApp application",                             "action": "navigate",  "target_desc": "WhatsApp app icon",                      "param_ref": null},
    {"intent": "Tap the compose / new message icon to start a fresh chat",  "action": "click",     "target_desc": "compose pencil icon (top-right)",        "param_ref": null},
    {"intent": "Search for the recipient by name",                          "action": "type",      "target_desc": "To: search field",                       "param_ref": "recipient_name"},
    {"intent": "Select the matching contact from the suggestions list",      "action": "click",     "target_desc": "contact row in search results",          "param_ref": null},
    {"intent": "Tap the message input field",                               "action": "click",     "target_desc": "message input bar at bottom of chat",    "param_ref": null},
    {"intent": "Type the message content",                                  "action": "type",      "target_desc": "message input bar",                      "param_ref": "message_text"},
    {"intent": "Attach a file if an attachment path was provided",          "action": "click",     "target_desc": "paperclip / attachment icon",            "param_ref": "attachment_path"},
    {"intent": "Send the message",                                          "action": "click",     "target_desc": "green Send button (arrow icon)",         "param_ref": null}
  ],
  "success_checks": [
    "Message appears in the chat with a single grey tick (sent)",
    "Tick turns to double grey ticks (delivered to recipient device)",
    "No error toast or 'failed to send' indicator is shown"
  ],
  "embedding": [],
  "stats": {"uses": 9, "successes": 9, "failures": 0, "success_rate": 1.0, "avg_steps": 7.2},
  "version": 1,
  "status": "active"
}
