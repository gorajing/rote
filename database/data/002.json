{
  "name": "buy_vintage_item_ebay",
  "site": "ebay",
  "goal_template": "Search for {item_description} on eBay using {listing_type} listings, verify seller rating, and complete purchase within {max_price} budget",
  "params": [
    {"name": "item_description", "type": "str",   "required": true},
    {"name": "listing_type",     "type": "str",   "required": false},
    {"name": "max_price",        "type": "float", "required": false}
  ],
  "preconditions": {
    "url_pattern": "ebay.com",
    "landmarks": ["search bar", "sign in link", "filter sidebar"]
  },
  "steps": [
    {"intent": "Navigate to the eBay homepage",                             "action": "navigate",  "target_desc": "address bar",                               "param_ref": null},
    {"intent": "Enter the item description in the search bar",              "action": "type",      "target_desc": "main search input",                         "param_ref": "item_description"},
    {"intent": "Submit the search",                                         "action": "press_key", "target_desc": "search input",                              "param_ref": null},
    {"intent": "Filter by listing type (Buy It Now or Auction)",            "action": "click",     "target_desc": "listing type filter option",                "param_ref": "listing_type"},
    {"intent": "Set maximum price to stay within budget",                   "action": "type",      "target_desc": "max price input in filter sidebar",         "param_ref": "max_price"},
    {"intent": "Restrict items to the user's country to reduce shipping",   "action": "click",     "target_desc": "Item Location filter — 'Within country'",   "param_ref": null},
    {"intent": "Open the most promising listing",                           "action": "click",     "target_desc": "top result listing title link",             "param_ref": null},
    {"intent": "Read the item description and inspect photos",              "action": "scroll",    "target_desc": "item description section",                  "param_ref": null},
    {"intent": "Verify seller feedback score is 98 %+ positive",           "action": "click",     "target_desc": "seller feedback score link",                "param_ref": null},
    {"intent": "Initiate the purchase or place a bid",                      "action": "click",     "target_desc": "Buy It Now or Place bid button",            "param_ref": null},
    {"intent": "Confirm shipping address on checkout page",                 "action": "click",     "target_desc": "Confirm and pay button",                    "param_ref": null}
  ],
  "success_checks": [
    "Order confirmation page shown with item and seller details",
    "Confirmation email received with estimated delivery date",
    "Item visible in 'Purchase history' under My eBay"
  ],
  "embedding": [],
  "stats": {"uses": 4, "successes": 3, "failures": 1, "success_rate": 0.75, "avg_steps": 9.8},
  "version": 1,
  "status": "active"
}
