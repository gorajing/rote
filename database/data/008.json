{
  "name": "book_hotel_booking_com",
  "site": "booking",
  "goal_template": "Book a hotel in {destination} on Booking.com from {check_in} to {check_out} for {guests} guest(s), budget up to {max_price_per_night} per night, minimum review score 8",
  "params": [
    {"name": "destination",         "type": "str",   "required": true},
    {"name": "check_in",            "type": "str",   "required": true},
    {"name": "check_out",           "type": "str",   "required": true},
    {"name": "guests",              "type": "int",   "required": true},
    {"name": "max_price_per_night", "type": "float", "required": false},
    {"name": "free_cancellation",   "type": "bool",  "required": false}
  ],
  "preconditions": {
    "url_pattern": "booking.com",
    "landmarks": ["destination search box", "date picker", "guests selector", "Search button"]
  },
  "steps": [
    {"intent": "Navigate to Booking.com and sign in",                               "action": "navigate", "target_desc": "booking.com in address bar",                       "param_ref": null},
    {"intent": "Enter the destination in the search widget",                        "action": "type",     "target_desc": "destination / property name input",                "param_ref": "destination"},
    {"intent": "Select the check-in date from the calendar",                        "action": "click",    "target_desc": "check-in date field then the correct date cell",   "param_ref": "check_in"},
    {"intent": "Select the check-out date from the calendar",                       "action": "click",    "target_desc": "check-out date cell",                              "param_ref": "check_out"},
    {"intent": "Set the number of guests",                                          "action": "click",    "target_desc": "guests / rooms selector, increment adults",        "param_ref": "guests"},
    {"intent": "Run the search",                                                    "action": "click",    "target_desc": "blue Search button",                               "param_ref": null},
    {"intent": "Apply maximum price-per-night filter",                              "action": "click",    "target_desc": "price range slider — drag upper handle",           "param_ref": "max_price_per_night"},
    {"intent": "Filter for free-cancellation rooms if requested",                   "action": "click",    "target_desc": "Free cancellation filter checkbox",                "param_ref": "free_cancellation"},
    {"intent": "Filter for 'Very Good' guest review score (8+)",                    "action": "click",    "target_desc": "Guest rating filter — Very Good checkbox",         "param_ref": null},
    {"intent": "Open the best-matching property",                                   "action": "click",    "target_desc": "top result property card",                         "param_ref": null},
    {"intent": "Select the appropriate room type",                                  "action": "click",    "target_desc": "I'll reserve / Reserve button next to room type", "param_ref": null},
    {"intent": "Fill in guest name and contact details on the booking form",        "action": "type",     "target_desc": "guest name, email, and phone fields",             "param_ref": null},
    {"intent": "Enter payment details",                                             "action": "type",     "target_desc": "credit card number, expiry, and CVV fields",      "param_ref": null},
    {"intent": "Confirm and complete the booking",                                  "action": "click",    "target_desc": "Complete booking button",                          "param_ref": null}
  ],
  "success_checks": [
    "Booking confirmation page shown with booking reference number",
    "Confirmation email received with hotel address and check-in instructions",
    "Booking visible under 'My Bookings' in the account dashboard"
  ],
  "embedding": [],
  "stats": {"uses": 8, "successes": 7, "failures": 1, "success_rate": 0.875, "avg_steps": 13.1},
  "version": 1,
  "status": "active"
}
