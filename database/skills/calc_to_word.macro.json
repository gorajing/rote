{
  "name": "calculator_to_word_save",
  "app": "Microsoft Word",
  "os": "macos",
  "description": "Performs a calculation in Calculator, copies the result, pastes it into a new Word document, and saves the document as 'calc_result' on the Desktop.",
  "params": {
    "calculation": "1234+5678",
    "filename": "calc_result"
  },
  "steps": [
    {
      "op": "open_app",
      "app": "Calculator",
      "launch_wait": 6,
      "why": "Focus the Calculator app"
    },
    {
      "op": "key",
      "key": "escape",
      "why": "Clear any existing calculation"
    },
    {
      "op": "type",
      "text": "1234+5678=",
      "why": "Perform the calculation 1234 + 5678"
    },
    {
      "op": "hotkey",
      "keys": ["command", "c"],
      "why": "Copy the calculation result"
    },
    {
      "op": "open_app",
      "app": "Microsoft Word",
      "launch_wait": 6,
      "why": "Switch to Microsoft Word"
    },
    {
      "op": "hotkey",
      "keys": ["command", "n"],
      "why": "Create a new document or open the template chooser"
    },
    {
      "op": "wait",
      "seconds": 2,
      "why": "Wait for Word to handle the new document action"
    },
    {
      "op": "key",
      "key": "return",
      "why": "Select Blank Document in the template chooser if it appears"
    },
    {
      "op": "wait",
      "seconds": 2,
      "why": "Wait for the blank document to open"
    },
    {
      "op": "type",
      "text": "Calculation result: ",
      "why": "Type the label text in the document"
    },
    {
      "op": "hotkey",
      "keys": ["command", "v"],
      "why": "Paste the calculation result"
    },
    {
      "op": "wait",
      "seconds": 1,
      "why": "Wait for the paste operation to complete"
    },
    {
      "op": "hotkey",
      "keys": ["command", "s"],
      "why": "Trigger the save dialog"
    },
    {
      "op": "wait",
      "seconds": 2,
      "why": "Wait for the save dialog to appear"
    },
    {
      "op": "hotkey",
      "keys": ["command", "d"],
      "why": "Set the save destination to the Desktop"
    },
    {
      "op": "wait",
      "seconds": 1,
      "why": "Wait for the folder selection to update"
    },
    {
      "op": "type",
      "text": "calc_result",
      "why": "Type the file name"
    },
    {
      "op": "key",
      "key": "return",
      "why": "Confirm and save the document"
    }
  ]
}
