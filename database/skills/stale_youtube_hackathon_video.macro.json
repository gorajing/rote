{
  "schema_version": 2,
  "surface": "browser",
  "name": "stale_youtube_hackathon_video",
  "app": "YouTube",
  "os": "any",
  "version": 1,
  "parent_version": null,
  "status": "active",
  "note": "Stale demo: reaches YouTube search results but incorrectly assumes the top video opened.",
  "start_url": "https://www.youtube.com",
  "reset": {
    "type": "navigate",
    "start_url": "https://www.youtube.com"
  },
  "params": {
    "query": "AI Engineer World's Hackathon"
  },
  "checker": {
    "type": "condition",
    "condition": {
      "url_contains": "/watch"
    }
  },
  "stats": {
    "uses": 0,
    "successes": 0,
    "failures": 0,
    "success_rate": 0.0,
    "avg_duration": 0.0,
    "model_calls": 0
  },
  "steps": [
    {
      "id": "open_search_results",
      "op": "navigate",
      "url": "https://www.youtube.com/results?search_query=AI+Engineer+World%27s+Hackathon",
      "precondition": {},
      "postcondition": {
        "url_contains": "/results",
        "text_contains": "AI Engineer"
      },
      "timeout": 15,
      "retry_limit": 1,
      "fallback": [],
      "why": "Search YouTube for AI Engineer World's Hackathon"
    },
    {
      "id": "stale_open_top_video",
      "op": "wait",
      "seconds": 1,
      "precondition": {
        "url_contains": "/results"
      },
      "postcondition": {
        "url_contains": "/watch"
      },
      "timeout": 2,
      "retry_limit": 0,
      "fallback": [],
      "why": "Open the first video result; this stale step no longer performs the required click"
    }
  ]
}
